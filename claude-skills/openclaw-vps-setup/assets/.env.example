# OpenClaw VPS environment variables
# Copy to ~/openclaw/.env on the VPS, fill in real values, then chmod 600.
# Do NOT commit this file with real values to version control.

# === LLM API Keys ===
# Use whichever provider matches openclaw.json defaults.model.primary
ANTHROPIC_API_KEY=sk-ant-api03-...
# OPENAI_API_KEY=sk-proj-...
# OPENROUTER_API_KEY=sk-or-...

# === OpenClaw Image (pin to known-good tag) ===
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.23

# === Discord Bot Tokens ===
# One per agent. Each token comes from a different Discord application.
# Token format starts with M... or N... (Bot Token, NOT Application ID).
DISCORD_BOT_TOKEN_AGENT_1=M...your-first-bot-token...
# DISCORD_BOT_TOKEN_AGENT_2=M...
# DISCORD_BOT_TOKEN_AGENT_3=M...

# === Optional: Hetzner API token (for advanced automation) ===
# HCLOUD_TOKEN=...
